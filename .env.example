# Copy to .env.local and fill in real values. Never commit .env.local.

GITHUB_TOKEN=
VERCEL_API_TOKEN=
SUPABASE_SECRET_KEY=
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
# Sandbox only: redirect all chase emails here (unverified Resend sender can
# only deliver to the account owner). Leave blank once a domain is verified.
RESEND_TEST_RECIPIENT=

# QuickBooks Online
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:3000/api/qbo/callback
QBO_ENVIRONMENT=sandbox
