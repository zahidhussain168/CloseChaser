# RuledOff API — environment
# Copy to .env and fill in. Never commit .env.

# Server
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed browser origins (the Next.js frontend).
CORS_ORIGINS=http://localhost:3000,https://ruledoff.vercel.app

# Supabase (same project as the RuledOff app)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Public base URL of the client-facing magic-link pages (the frontend)
APP_URL=https://ruledoff.vercel.app

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
# Sandbox only: redirect all chase emails here instead of the real client.
RESEND_TEST_RECIPIENT=

# Cron scheduler auth
CRON_SECRET=

# QuickBooks Online (Intuit)
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=sandbox
QBO_REDIRECT_URI=http://localhost:4000/api/qbo/callback
# 32-byte hex/base64 key for AES-256-GCM encryption of QBO refresh tokens
ENCRYPTION_KEY=

# Paddle billing
PADDLE_API_KEY=
PADDLE_ENV=sandbox
PADDLE_PRICE_ID=
PADDLE_WEBHOOK_SECRET=

# AI email generation (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
